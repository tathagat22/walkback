{
  "name": "@walkback/engine",
  "version": "0.2.1",
  "description": "NAPI-built native binding to the Rust undo engine.",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": "https://github.com/tathagat22/walkback",
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "name": "walkback-engine",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin"
      ]
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ],
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm --skip-gh-release"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
