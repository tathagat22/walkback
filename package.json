{
  "name": "@agent-undo/core",
  "version": "0.1.0",
  "description": "Ctrl-Z for AI agents. A universal time machine that records every side effect an autonomous agent produces — file writes, shell commands, git state, HTTP mutations — and reverses them with one command.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "ai",
    "agents",
    "undo",
    "rollback",
    "mcp",
    "model-context-protocol",
    "time-machine",
    "reversible",
    "autonomous-agents",
    "claude"
  ],
  "bin": {
    "undo": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "cli": "tsx src/cli.ts",
    "mcp": "tsx src/mcp.ts",
    "demo": "tsx demo/demo.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
